msgid "Return a string describing the alternate function."
msgstr "返回描述替代功能的字符串。"

#: ../../library/pyb.Pin.rst:260
msgid "Return the alternate function index."
msgstr "返回替代功能索引。"

#: ../../library/pyb.Pin.rst:264
msgid "Return the name of the alternate function."
msgstr "返回替代功能的名称。"

