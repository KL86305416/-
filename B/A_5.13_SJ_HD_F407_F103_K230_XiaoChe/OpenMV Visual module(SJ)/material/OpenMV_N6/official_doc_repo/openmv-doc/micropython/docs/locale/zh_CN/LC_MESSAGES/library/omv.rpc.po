msgstr "创建一个SPI ``rpc`` 主设备。该接口可以动达 80 Mb/s。"

#: ../../library/omv.rpc.rst:340 ../../library/omv.rpc.rst:358
msgid "cs_pin - Slave Select Pin."
msgstr "cs_pin - 从设备选择引脚。"

#: ../../library/omv.rpc.rst:341
