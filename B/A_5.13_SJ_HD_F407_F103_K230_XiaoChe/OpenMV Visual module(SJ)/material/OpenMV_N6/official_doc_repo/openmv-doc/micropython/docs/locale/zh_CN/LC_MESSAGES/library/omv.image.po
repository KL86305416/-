msgstr "TAG36H11 -> 0 到 586"

#: ../../library/omv.image.rst:1144
msgid "ARTOOLKIT -> 0 to 511"
msgstr "ARTOOLKIT -> 0 到 511"

#: ../../library/omv.image.rst:1150
msgid "Returns the numeric family of the apriltag."
msgstr "返回 apriltag 的数字家族。"

#: ../../library/omv.image.rst:1152
