msgid "Reason"
msgstr "原因"

#: ../../library/machine.CAN.rst:219
msgid "0"
msgstr "0"

#: ../../library/machine.CAN.rst:219
msgid "A message has been accepted into a empty FIFO."
msgstr "消息已被接受到空的FIFO中。"

#: ../../library/machine.CAN.rst:221
msgid "1"
msgstr "1"

#: ../../library/machine.CAN.rst:221
msgid "The FIFO is full"
msgstr "FIFO已满"

#: ../../library/machine.CAN.rst:223
msgid "A message has been lost due to a full FIFO"
msgstr "由于FIFO已满，消息已丢失"

